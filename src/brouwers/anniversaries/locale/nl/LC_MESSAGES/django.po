#: src/brouwers/anniversaries/models.py:10
msgid "date"
msgstr "datum"

#: src/brouwers/anniversaries/models.py:11
msgid "The day on which this significant event happened."
msgstr "De datum waarop deze gebeurtenis plaats vond."

#: src/brouwers/anniversaries/models.py:14
msgid "title"
msgstr "titel"

#: src/brouwers/anniversaries/models.py:16
msgid "Short title that should invite the user to read more."
msgstr "Korte titel die de lezer uitnodigt om meer te lezen."

#: src/brouwers/anniversaries/models.py:19
msgid "body text"
msgstr "inhoudtekst"

#: src/brouwers/anniversaries/models.py:21
msgid "The full text providing more context about this specific moment."
msgstr "De volledige tekst die dit specifieke moment in detail beschrijft."

#: src/brouwers/anniversaries/models.py:24
msgid "image"
msgstr "afbeelding"

#: src/brouwers/anniversaries/models.py:27
msgid "An image to display on the timeline."
msgstr "Een afbeelding om op de tijdlijn weer te geven."

#: src/brouwers/anniversaries/models.py:30
msgid "image alt text"
msgstr "toegankelijke alt-tekst"

#: src/brouwers/anniversaries/models.py:33
msgid ""
"Describe what's visible in the image for users with visual impairments. An "
"alt text is required if you upload an image."
msgstr ""
"Beschrijf wat de afbeelding afbeeldt zodat gebruikers met visuele "
"beperkingen de afbeelding ook begrijpen. Je moet een toegankelijke tekst "
"opgeven als je een afbeelding toevoegt."

#: src/brouwers/anniversaries/models.py:39
msgid "remarkable event"
msgstr "bijzondere gebeurtenis"

#: src/brouwers/anniversaries/models.py:40
msgid "remarkable events"
msgstr "bijzondere gebeurtenisen"

#: src/brouwers/anniversaries/models.py:52
msgid ""
"You must provide an alt text when adding an image to ensure accessibilty."
msgstr ""
"Je moet een toegankelijke alt-tekst opgeven wanneer je een afbeelding "
"toevoegt zodat gebruikers met visuele beperkingen ook de pagina kunnen "
"gebruiken."

#: src/brouwers/anniversaries/templates/anniversaries/20.html:4
msgid "20 years anniversary"
msgstr "20 jaar Modelbrouwers"

#: src/brouwers/anniversaries/templates/anniversaries/20.html:13
msgid "20 years Modelbrouwers.nl!"
msgstr "20 jaar Modelbrouwers.nl!"
